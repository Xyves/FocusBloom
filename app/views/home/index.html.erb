<main class="w-full min-h-screen" data-controller="settings">
  <div class="relative flex min-h-screen w-full items-center justify-center bg-cover bg-center bg-no-repeat text-white"
       data-settings-target="background">
    <section class="w-full px-4 sm:px-6 lg:px-8">
      <div class="mx-auto flex w-full max-w-screen-xl flex-col items-center">
        <section id="timer" class="w-full select-none text-center">
          <div data-controller="countdown"
               data-action="settings:changed@window->countdown#applySettings">

            <%= render 'home/timer/top_navigation' %>
            <%= render 'home/timer/timer' %>
            <%= render 'home/timer/bottom_navigation' %>

          </div>
        </section>
      </div>
    </section>

    <%= render 'home/settings/settings_notification' %>

    <div class="fixed bottom-4 right-4 z-50 sm:bottom-6 sm:right-6">
      <%= render 'home/settings/settings_button' %>
    </div>

    <%= render 'home/settings/settings_modal' %>
  </div>
</main>